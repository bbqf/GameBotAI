<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <!-- .jscript extension keeps CodeQL's ECMAScript parser away from MSI-only
         JScript syntax (e.g. Session.Property("X") = "value"); the script engine
         is selected by JScriptCall below, not by the file extension. -->
    <Binary Id="PortResolverScript" SourceFile="Scripts\PortResolver.jscript" />

    <CustomAction
      Id="DetectAvailablePorts"
      BinaryRef="PortResolverScript"
      JScriptCall="DetectAvailablePorts"
      Execute="immediate"
      Return="check" />

    <CustomAction
      Id="DiscoverBindInterfaces"
      BinaryRef="PortResolverScript"
      JScriptCall="DiscoverBindInterfaces"
      Execute="immediate"
      Return="ignore" />

    <CustomAction
      Id="NormalizeStartMenuShortcut"
      BinaryRef="PortResolverScript"
      JScriptCall="NormalizeStartMenuShortcut"
      Execute="immediate"
      Return="ignore" />

    <InstallUISequence>
      <Custom Action="DiscoverBindInterfaces" Before="DetectAvailablePorts" Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED AND PERSISTED_PORT = &quot;&quot; AND PERSISTED_BIND_HOST = &quot;&quot; AND UILevel &gt;= 5" />
      <Custom Action="DetectAvailablePorts" Before="CostFinalize" Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED AND PERSISTED_PORT = &quot;&quot; AND PERSISTED_BIND_HOST = &quot;&quot; AND UILevel &gt;= 5" />
    </InstallUISequence>
    <InstallExecuteSequence>
      <Custom Action="DetectAvailablePorts" Before="CostFinalize" Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED AND PERSISTED_PORT = &quot;&quot; AND PERSISTED_BIND_HOST = &quot;&quot; AND UILevel &lt; 5" />
      <Custom Action="NormalizeStartMenuShortcut" After="CreateShortcuts" Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED AND NOT REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Fragment>
</Wix>
